# =============================================================================
# Local secrets for tech-news. Copy this file to ".env" and fill in your values.
# The .env file is gitignored — your real secrets never get committed.
# =============================================================================

# Anthropic API key — get one at https://console.anthropic.com
# (Settings -> API Keys -> Create Key)
ANTHROPIC_API_KEY=sk-ant-paste-your-key-here

# Your Gmail address (the digest will appear to come from here).
GMAIL_FROM_ADDRESS=you@gmail.com

# A Gmail "App Password" (NOT your regular Gmail login password!).
# Generate one at https://myaccount.google.com/apppasswords
# Requires 2-factor auth to be enabled on your Google account.
# Looks like: "xxxx xxxx xxxx xxxx"  (spaces are OK)
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Where to deliver the digest. Usually the same as GMAIL_FROM_ADDRESS
# (sending to yourself), but it can be any address.
DIGEST_TO_ADDRESS=you@gmail.com
